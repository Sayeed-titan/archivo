// Archivo — tenant-aware Event/Archive Management schema.
// Every domain table is scoped by organizationId so a single deployment
// can serve multiple customer organizations (see HANDOFF.md point 14).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Tenancy & Identity ──────────────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  industry  String? // e.g. "ngo", "healthcare", "education" — informational, not a schema branch
  // Which "open in" connector this org uses for Office-type documents.
  // Pluggable per HANDOFF.md point 5 — Google today, Microsoft stubbed.
  docEditorProvider String? // "google" | "microsoft" | null (not configured)
  // Storage limit warning (SRS.md FR-10.1 / NFR-2): notify as usage
  // approaches this ceiling. Null = no limit configured/enforced yet.
  storageQuotaBytes BigInt?
  // SRS.md FR-11.5: optional watermark on downloaded images / exported
  // PDF reports. Off by default — an org opts in and sets the text.
  watermarkEnabled Boolean @default(false)
  watermarkText    String? // null = fall back to Organization.name at render time
  // Material Design 3 theming (org brand). The seed color drives the full
  // MD3 light+dark color scheme, generated at render time in src/lib/theme/.
  // Editable at /settings/appearance (canManageSettings).
  themeSeedColor String @default("#6750A4") // any hex; MD3 baseline purple by default
  themeMode      String @default("system") // "light" | "dark" | "system" — org default; User.themePreference overrides
  themeShape     String @default("standard") // "sharp" | "standard" | "rounded" — global corner-radius scale
  themeFontScale String @default("medium") // "small" | "medium" | "large" — global base font size
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users           User[]
  roles           Role[]
  categories      Category[]
  lookupLists     LookupList[]
  folderTemplates FolderTemplate[]
  customFields    CustomFieldDefinition[]
  archives        Archive[]
  auditLogs       AuditLog[]
  integrations    OrgIntegration[]
  reportTemplates ReportTemplate[]
  notifications   Notification[]
  workflowStates      WorkflowState[]
  workflowTransitions WorkflowTransition[]
  shareLinks          ShareLink[]

  @@map("organizations")
}

// Configurable approval workflow (HANDOFF.md point 7 / Prompt 7): each
// org defines its own ordered sequence of statuses instead of a fixed
// Draft→Archived assumption. Archive.status stays a plain string (it
// already was one) — WorkflowState is the org's *declared vocabulary* of
// valid values for that string, not a foreign key, so existing archives
// with a status outside the current workflow never become unreadable if
// an admin edits the workflow later.
model WorkflowState {
  id             String  @id @default(cuid())
  organizationId String
  name           String // must match values used in Archive.status
  order          Int
  isInitial      Boolean @default(false) // the status new archives start in
  isTerminal     Boolean @default(false) // e.g. "Archived" — no further transitions expected

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@map("workflow_states")
}

// A single allowed state-to-state move, plus what must be true about an
// archive before that move is allowed. Kept as JSON (not booleans) so new
// requirement kinds (custom fields, approvals, etc.) don't need schema
// changes — see src/lib/workflow/requirements.ts for the shape and
// evaluation logic.
model WorkflowTransition {
  id             String @id @default(cuid())
  organizationId String
  fromState      String
  toState        String
  // e.g. [{ "kind": "mandatoryFoldersFilled" }, { "kind": "fieldRequired", "field": "donor" }]
  requirements   Json   @default("[]")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, fromState, toState])
  @@map("workflow_transitions")
}

// In-app notifications (SRS.md FR-10 / Prompt 6): archive created, missing
// required documents, upload completed, review pending, storage limit
// warning. Each notification targets one recipient user; broadcast-style
// events (e.g. storage warning to all Admins) create one row per
// recipient rather than a fan-out join table, since read/unread state is
// inherently per-user.
model Notification {
  id             String   @id @default(cuid())
  organizationId String
  recipientId    String
  type           String // "archive_created" | "missing_documents" | "upload_completed" | "review_pending" | "storage_limit"
  message        String
  linkPath       String? // e.g. "/archives/<id>" — where clicking the notification should go
  readAt         DateTime?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  recipient    User         @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([organizationId, recipientId, readAt])
  @@map("notifications")
}

// Dynamic report builder (HANDOFF.md point 4): an admin picks fields +
// filters and saves the combination as a reusable template, instead of
// the app shipping 7 hardcoded report pages. The 7 SRS reports (Archive
// Register, Documents by Event/Year, Upload Activity, Storage Usage,
// Missing Documents, User Activity) are seeded as ReportTemplate rows
// using this same engine — see prisma/seed.ts and src/lib/reports/.
model ReportTemplate {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  // Archive-level field keys to include as report columns, e.g.
  // ["archiveNumber", "name", "category", "donor", "fileCount"].
  // See src/lib/reports/fields.ts for the full catalog (raw columns +
  // computed ones like fileCount/storageBytes/missingMandatoryFolders).
  fields         Json
  // Filter conditions as a small typed shape (field, operator, value) —
  // see src/lib/reports/filters.ts. Kept as JSON because filter shapes
  // vary by field type (date range vs. text-equals vs. status-in), and
  // this list grows without needing schema migrations.
  filters        Json     @default("[]")
  isSystemDefault Boolean @default(false) // true for the 7 SRS starter templates
  createdById    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation(fields: [createdById], references: [id])

  @@unique([organizationId, name])
  @@map("report_templates")
}

// Stores OAuth/API credentials an organization has connected for a given
// provider (Google Workspace today; Microsoft 365 stubbed — see
// src/lib/connectors/). One row per org+provider; tokens are the only
// provider-specific payload, kept as JSON so each connector owns its own
// shape without further schema changes.
model OrgIntegration {
  id             String   @id @default(cuid())
  organizationId String
  provider       String // "google" | "microsoft"
  credentials    Json // refresh_token, access_token, expiry, scope, etc.
  connectedById  String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  connectedBy  User         @relation(fields: [connectedById], references: [id])

  @@unique([organizationId, provider])
  @@map("org_integrations")
}

// Fixed system roles ship as seeded rows (Administrator, Archive Officer,
// Department User, Viewer per SRS 3.9) but Role is a table, not an enum,
// so an organization can add its own roles/permission sets later without
// a schema migration.
model Role {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  // Permission flags per SRS 3.9 matrix. Kept as explicit booleans (not a
  // JSON bag) because these gate real authorization checks — flexibility
  // here belongs in future custom roles' *values*, not in hiding the checks.
  canCreateArchive  Boolean @default(false)
  canUpload         Boolean @default(false)
  canEditMetadata   Boolean @default(false)
  canDeleteArchive  Boolean @default(false)
  canHardDelete     Boolean @default(false)
  canManageUsers    Boolean @default(false)
  canManageSettings Boolean @default(false)
  canGenerateReport Boolean @default(false)
  canViewAll        Boolean @default(false) // false = own/department scope only
  canDownload       Boolean @default(false)
  createdAt         DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  users        User[]

  @@unique([organizationId, name])
  @@map("roles")
}

model User {
  id             String   @id @default(cuid())
  organizationId String
  email          String
  passwordHash   String
  name           String
  department     String?
  roleId         String
  isActive       Boolean  @default(true)
  // SRS.md FR-10.2: email is a configurable enhancement on top of in-app
  // notifications, opt-in per user (default on — matches "notify by
  // default" expectation, users who don't want it can turn it off).
  emailNotificationsEnabled Boolean @default(true)
  // Per-user light/dark override: "light" | "dark" | "system" | null
  // (null = follow the org's themeMode default). Toggled from the top app bar.
  themePreference String?
  // Profile photo, stored under storage/avatars/ (see src/lib/file-storage.ts).
  // Null = fall back to computed initials, same as today.
  avatarPath     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization      Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role              Role              @relation(fields: [roleId], references: [id])
  createdArchives   Archive[]         @relation("ArchiveCreatedBy")
  uploadedFiles     File[]            @relation("FileUploadedBy")
  auditLogs         AuditLog[]
  externalDocLinks  ExternalDocLink[]
  connectedIntegrations OrgIntegration[]
  reportTemplates   ReportTemplate[]
  notifications     Notification[]
  shareLinks        ShareLink[]

  @@unique([organizationId, email])
  @@map("users")
}

// ── Configurable taxonomy (point 11: managed lookup lists, not free text) ──

model Category {
  id             String  @id @default(cuid())
  organizationId String
  name           String
  order          Int     @default(0)
  isActive       Boolean @default(true)

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  folderTemplates FolderTemplate[]
  archives        Archive[]

  @@unique([organizationId, name])
  @@map("categories")
}

// Generic managed lookup list for Donor / Project / Department style
// fields, so free text never fragments a value like "Global Health Trust"
// vs "Global Health Trust Foundation" (HANDOFF.md point 11).
model LookupList {
  id             String @id @default(cuid())
  organizationId String
  key            String // e.g. "donor", "project", "department"

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  items        LookupListItem[]

  @@unique([organizationId, key])
  @@map("lookup_lists")
}

model LookupListItem {
  id           String  @id @default(cuid())
  lookupListId String
  value        String
  isActive     Boolean @default(true)

  lookupList LookupList @relation(fields: [lookupListId], references: [id], onDelete: Cascade)

  @@unique([lookupListId, value])
  @@map("lookup_list_items")
}

// ── Folder templates per category (point 1) ─────────────────────────

model FolderTemplate {
  id             String  @id @default(cuid())
  organizationId String
  categoryId     String
  name           String // e.g. "01 Proposal"
  order          Int
  isMandatory    Boolean @default(false)
  // Upload rules (allowed types, min resolution, max size, per-type min/max
  // counts, alternate document options, external-link fallback) — parsed/
  // validated by src/lib/folder-rules.ts. JSON so new rule kinds don't need
  // a migration, same pattern as WorkflowTransition.requirements.
  rules          Json    @default("{}")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category     Category     @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  folders      Folder[]

  @@unique([categoryId, name])
  @@map("folder_templates")
}

// ── Custom fields (point 2: org-configurable metadata, not fixed columns) ──

model CustomFieldDefinition {
  id             String   @id @default(cuid())
  organizationId String
  key            String // machine key, e.g. "consent_obtained"
  label          String // display label
  fieldType      String // "text" | "number" | "date" | "boolean" | "select"
  options        Json? // for "select" type
  isRequired     Boolean  @default(false)
  order          Int      @default(0)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, key])
  @@map("custom_field_definitions")
}

// ── Archive (the core entity) ────────────────────────────────────────

model Archive {
  id             String   @id @default(cuid())
  organizationId String
  archiveNumber  String // human-facing auto ID, e.g. "ARC-2026-00042"
  name           String // the only required field at creation (Zero-Friction Capture, point 9)
  categoryId     String?
  department     String?
  eventDate      DateTime?
  venue          String?
  organizer      String?
  coordinator    String?
  donor          String?
  projectName    String?
  tags           String[] @default([])
  description    String?
  status         String   @default("Draft") // Draft | Pending Review | Archived | org-defined (point 7)
  // Org-configurable metadata that doesn't warrant a fixed column
  // (CustomFieldDefinition supplies the schema; this holds the values).
  customFields   Json     @default("{}")
  isMigrationInbox Boolean @default(false) // true for the always-open backlog bucket (point 3)

  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime? // soft delete (point 5)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category     Category?    @relation(fields: [categoryId], references: [id])
  createdBy    User         @relation("ArchiveCreatedBy", fields: [createdById], references: [id])
  folders      Folder[]

  @@unique([organizationId, archiveNumber])
  @@index([organizationId, status])
  @@index([organizationId, donor])
  @@map("archives")
}

model Folder {
  id               String  @id @default(cuid())
  archiveId        String
  name             String
  order            Int
  isMandatory      Boolean @default(false)
  // Links back to the FolderTemplate this folder was instantiated from, so
  // upload rules can be looked up live (rules aren't re-snapshotted onto
  // Folder). Null for archives created before this field existed, or for
  // folders with no originating template (e.g. the inbox's "Unsorted") —
  // uploads into those folders simply have no rules enforced.
  folderTemplateId String?

  archive        Archive         @relation(fields: [archiveId], references: [id], onDelete: Cascade)
  folderTemplate FolderTemplate? @relation(fields: [folderTemplateId], references: [id], onDelete: SetNull)
  files          File[]

  @@unique([archiveId, name])
  @@map("folders")
}

model File {
  id            String    @id @default(cuid())
  folderId      String
  filename      String
  fileType      String // pdf | word | excel | powerpoint | image | video | audio | zip
  mimeType      String
  sizeBytes     Int
  storagePath   String
  version       Int       @default(1)
  isLatest      Boolean   @default(true)
  // Re-upload of the same logical document creates a new File row pointing
  // back at the one it superseded, instead of overwriting it in place —
  // the whole chain stays retrievable (HANDOFF.md point 5).
  previousVersionId String? @unique
  consentFlag   Boolean? // photo consent/safeguarding flag (point 10), null when not applicable
  externalDocId String? // ID assigned by an external editor connector (see ExternalDocLink), duplicated here for quick lookup
  // SRS.md FR-6.2: auto-generated for fileType="video" at upload time via
  // ffmpeg (see src/lib/video-processing.ts). Null for non-video files or
  // if extraction failed (e.g. corrupt upload) — never blocks the upload.
  thumbnailPath   String?
  durationSeconds Int?
  // Which configured FolderRules.alternateOptions.options label (e.g.
  // "Tender" vs "TOR") this upload satisfies; null when the folder has no
  // alternate-options rule configured.
  alternateOptionLabel String?
  // External-link fallback (FolderRules.externalLinkFallback): used when a
  // file exceeds the folder's max size. storagePath/mimeType are empty
  // placeholders and sizeBytes is 0 in this case — externalUrl is the real
  // payload. Still counts toward that file type's min/max counts.
  isExternalLink  Boolean   @default(false)
  externalUrl     String?
  uploadedById  String
  uploadedAt    DateTime  @default(now())
  deletedAt     DateTime? // soft delete

  folder          Folder         @relation(fields: [folderId], references: [id], onDelete: Cascade)
  uploadedBy      User           @relation("FileUploadedBy", fields: [uploadedById], references: [id])
  downloads       FileDownload[]
  previousVersion File?          @relation("FileVersionHistory", fields: [previousVersionId], references: [id])
  nextVersion     File?          @relation("FileVersionHistory")
  externalDocLink ExternalDocLink?
  shareLinks      ShareLink[]

  @@index([folderId, isLatest])
  @@map("files")
}

// Public, unauthenticated file sharing (point 15 of the UI upgrade plan):
// a token grants access to exactly one File without requiring the
// recipient to have an Archivo login — meant for sharing via WhatsApp/
// email to people outside the organization. Scoped to a single file, not
// a folder/archive (bulk multi-file sharing stays an authenticated,
// in-app action — see the bulk zip download feature).
model ShareLink {
  id             String    @id @default(cuid())
  organizationId String
  fileId         String
  token          String    @unique @default(cuid())
  createdById    String
  expiresAt      DateTime?
  maxDownloads   Int?
  downloadCount  Int       @default(0)
  createdAt      DateTime  @default(now())
  revokedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  file         File         @relation(fields: [fileId], references: [id], onDelete: Cascade)
  createdBy    User         @relation(fields: [createdById], references: [id])

  @@index([fileId])
  @@map("share_links")
}

// Pluggable "open in" integration (Prompt 4): a File can be linked to a
// document in an external editor (Google Workspace today, Microsoft 365
// later). One row per file; `provider` selects which connector interprets
// `externalId`/`externalUrl` — see src/lib/connectors/.
model ExternalDocLink {
  id           String   @id @default(cuid())
  fileId       String   @unique
  provider     String // "google" | "microsoft"
  externalId   String // e.g. Google Drive file ID
  externalUrl  String // direct "open in <provider>" link
  createdById  String
  createdAt    DateTime @default(now())

  file      File @relation(fields: [fileId], references: [id], onDelete: Cascade)
  createdBy User @relation(fields: [createdById], references: [id])

  @@map("external_doc_links")
}

model FileDownload {
  id           String   @id @default(cuid())
  fileId       String
  downloadedBy String
  downloadedAt DateTime @default(now())

  file File @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@map("file_downloads")
}

// ── Universal audit trail (point 8) ─────────────────────────────────

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  actorId        String
  action         String // "create" | "edit" | "delete" | "hard_delete" | "download" | ...
  entityType     String // "Archive" | "File" | "Folder" | "User" | ...
  entityId       String
  note           String? // optional reason, mandatory in practice for hard-delete
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actor        User         @relation(fields: [actorId], references: [id])

  @@index([organizationId, entityType, entityId])
  @@index([organizationId, createdAt])
  @@map("audit_logs")
}
